{
  "meta": {
    "lastTouchedVersion": "2026.4.21",
    "lastTouchedAt": "2026-04-23T12:34:17.555Z"
  },
  "update": {
    "checkOnStart": false
  },
  "gateway": {
    "bind": "loopback",
    "controlUi": {
      "allowInsecureAuth": true,
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789"
      ]
    },
    "mode": "local",
    "port": 18789,
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "auth": {
      "mode": "token",
      "token": "${GATEWAY_TOKEN}"
    }
  },
  "browser": {
    "headless": true,
    "noSandbox": true,
    "defaultProfile": "openclaw",
    "executablePath": "/usr/bin/chromium"
  },
  "secrets": {
    "providers": {
      "default": {
        "source": "env"
      }
    },
    "defaults": {
      "env": "default"
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "minimax/MiniMax-M2.7",
        "fallbacks": [
          "minimax/MiniMax-M2.7-highspeed"
        ]
      },
      "models": {
        "minimax/MiniMax-M2.7": {
          "alias": "Minimax"
        }
      },
      "compaction": {
        "mode": "safeguard"
      },
      "sandbox": {
        "mode": "all",
        "scope": "agent",
        "workspaceAccess": "rw",
        "docker": {
          "binds": [
            "/home/node/.openclaw/wiki/main:/workspace/shared/memory-wiki:ro",
            "/home/node/.openclaw/workspace-paper-review/outputs:/workspace/shared/paper-review-outputs:ro",
            "/home/node/.openclaw/workspace-idea-generate/idea-runs:/workspace/shared/idea-runs:ro"
          ]
        }
      },
      "elevatedDefault": "full",
      "maxConcurrent": 4,
      "subagents": {
        "delegationMode": "prefer",
        "maxConcurrent": 8,
        "maxSpawnDepth": 1,
        "allowAgents": ["autoresearch", "paper-review", "idea-generate", "reviewer"]
      }
    },
    "list": [
      {
        "id": "main",
        "name": "颖姗",
        "default": true,
        "workspace": "~/.openclaw/workspace"
      },
      {
        "id": "autoresearch",
        "name": "Autoresearch",
        "workspace": "~/.openclaw/workspace-autoresearch"
      },
      {
        "id": "paper-review",
        "name": "Paper Review",
        "workspace": "~/.openclaw/workspace-paper-review"
      },
      {
        "id": "idea-generate",
        "name": "Idea Generate",
        "workspace": "~/.openclaw/workspace-idea-generate"
      },
      {
        "id": "reviewer",
        "name": "Reviewer",
        "workspace": "~/.openclaw/workspace-reviewer"
      }
    ]
  },
  "bindings": [
    {
      "agentId": "main",
      "match": {
        "channel": "feishu",
        "accountId": "main"
      }
    },
    {
      "agentId": "main",
      "match": {
        "channel": "discord"
      }
    }
  ],
  "messages": {
    "ackReactionScope": "group-mentions",
    "tts": {
      "auto": "off",
      "mode": "final",
      "provider": "edge",
      "providers": {
        "edge": {
          "voice": "zh-CN-XiaoxiaoNeural",
          "lang": "zh-CN",
          "outputFormat": "ogg-24khz-16bit-mono-opus",
          "pitch": "+0Hz",
          "rate": "+0%",
          "volume": "+0%",
          "timeoutMs": 30000
        }
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto"
  },
  "tools": {
    "profile": "full",
    "sessions": {
      "visibility": "all"
    },
    "fs": {
      "workspaceOnly": true
    }
  },
  "channels": {
    "feishu": {
      "enabled": true,
      "domain": "feishu",
      "connectionMode": "websocket",
      "defaultAccount": "main",
      "accounts": {
        "main": {
          "appId": "${FEISHU_APP_ID}",
          "appSecret": "${FEISHU_APP_SECRET}",
          "name": "Research Assistant",
          "enabled": true
        },
        "default": {
          "dmPolicy": "pairing",
          "groupPolicy": "allowlist"
        }
      },
      "requireMention": true
    },
    "discord": {
      "enabled": true,
      "token": {
        "source": "env",
        "provider": "default",
        "id": "DISCORD_BOT_TOKEN"
      },
      "groupPolicy": "open"
    }
  },
  "plugins": {
    "entries": {
      "minimax": {
        "enabled": true
      },
      "browser": {
        "enabled": true
      },
      "lossless-claw": {
        "enabled": true,
        "config": {
          "freshTailCount": 64,
          "incrementalMaxDepth": 1,
          "contextThreshold": 0.75,
          "newSessionRetainDepth": 2
        }
      },
      "memory-core": {
        "config": {
          "dreaming": {
            "enabled": true
          }
        }
      },
      "memory-wiki": {
        "enabled": true,
        "config": {
          "vaultMode": "isolated",
          "vault": {
            "path": "~/.openclaw/wiki/main",
            "renderMode": "obsidian"
          },
          "obsidian": {
            "enabled": true,
            "useOfficialCli": true,
            "vaultName": "OpenClaw Wiki",
            "openAfterWrites": false
          },
          "bridge": {
            "enabled": false,
            "readMemoryArtifacts": true,
            "indexDreamReports": true,
            "indexDailyNotes": true,
            "indexMemoryRoot": true,
            "followMemoryEvents": true
          },
          "ingest": {
            "autoCompile": true,
            "maxConcurrentJobs": 1,
            "allowUrlIngest": true
          },
          "search": {
            "backend": "shared",
            "corpus": "wiki"
          },
          "context": {
            "includeCompiledDigestPrompt": false
          },
          "render": {
            "preserveHumanBlocks": true,
            "createBacklinks": true,
            "createDashboards": true
          }
        }
      }
    },
    "installs": {
      "lossless-claw": {
        "source": "path",
        "spec": "@martian-engineering/lossless-claw",
        "installPath": "/home/node/.openclaw/extensions/lossless-claw",
        "version": "0.5.2",
        "resolvedName": "@martian-engineering/lossless-claw",
        "resolvedVersion": "0.9.2",
        "resolvedSpec": "@martian-engineering/lossless-claw@0.9.2",
        "integrity": "sha512-T33c/xgqwmb2l3W/PaZxMYiG29wu1lhRGiZ034DVay85Xnubcsqq7cF0zKYqfpU3R572+8eWUw813595KMUwiw==",
        "shasum": "40fc865a4dd53f494cecae7a249dea5ac9126af1",
        "resolvedAt": "2026-04-22T16:13:46.239Z",
        "installedAt": "2026-04-23T04:27:08.670Z"
      }
    },
    "slots": {
      "contextEngine": "lossless-claw"
    }
  },
  "memory": {
    "backend": "qmd",
    "citations": "auto",
    "qmd": {
      "includeDefaultMemory": true,
      "sessions": {
        "enabled": true
      },
      "limits": {
        "timeoutMs": 8000,
        "maxResults": 16
      },
      "update": {
        "onBoot": true,
        "interval": "5m",
        "debounceMs": 15000
      },
      "command": "/usr/local/bin/qmd",
      "paths": [
        {
          "path": ".",
          "name": "workspace",
          "pattern": "**/*.md"
        }
      ]
    }
  },
  "session": {
    "dmScope": "per-peer"
  },
  "models": {
    "mode": "merge",
    "providers": {
      "minimax": {
        "baseUrl": "https://api.minimaxi.com/anthropic",
        "models": [
          {
            "id": "MiniMax-M2.7",
            "name": "MiniMax M2.7",
            "reasoning": true,
            "input": [
              "text",
              "image"
            ],
            "cost": {
              "input": 0.3,
              "output": 1.2,
              "cacheRead": 0.06,
              "cacheWrite": 0.375
            },
            "contextWindow": 204800,
            "maxTokens": 131072
          }
        ],
        "api": "anthropic-messages",
        "authHeader": true
      }
    }
  },
  "auth": {
    "profiles": {
      "minimax:cn": {
        "provider": "minimax",
        "mode": "api_key"
      }
    }
  },
  "wizard": {
    "lastRunAt": "2026-04-22T15:41:27.246Z",
    "lastRunVersion": "2026.4.9",
    "lastRunCommand": "configure",
    "lastRunMode": "local"
  }
}
